/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  padding: 20rpx 30rpx;
}

/* 主题色 */
.text-primary {
  color: #ff4d4f;
}

.bg-primary {
  background-color: #ff4d4f;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background: #ff4d4f;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.btn-default {
  background: #f0f0f0;
  color: #333;
  border-radius: 12rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
}
