<view class="page">
  <view class="container">
    <!-- 记录列表 -->
    <view class="record-list" wx:if="{{records.length > 0}}">
      <view class="record-item card" wx:for="{{records}}" wx:key="id" bindtap="viewDetail" data-item="{{item}}">
        <view class="record-thumb">
          <image wx:if="{{item.thumbnailUrl}}" src="{{item.thumbnailUrl}}" mode="aspectFill" class="thumb-img"></image>
          <view wx:elif="{{item.video}}" class="thumb-video">
            <text class="play-icon">▶</text>
          </view>
          <view wx:elif="{{item.accImg}}" class="thumb-photo">
            <image src="{{item.accImg.split(',')[0]}}" mode="aspectFill" class="thumb-img"></image>
          </view>
          <view wx:else class="thumb-placeholder">
            <text>无预览</text>
          </view>
        </view>
        <view class="record-info">
          <text class="record-type">{{item.video ? '视频' : '照片'}}</text>
          <text class="record-time">{{item.createTime}}</text>
          <view class="record-status">
            <text class="status-tag {{item.status === 4 ? 'status-claimed' : item.status === 2 ? 'status-pass' : item.status === 3 ? 'status-fail' : 'status-pending'}}">
              {{item.status === 4 ? '奖励已领取' : item.status === 2 ? '审核通过' : item.status === 3 ? '审核失败' : '待审核'}}
            </text>
          </view>
          <view class="reward-info" wx:if="{{item.rewardAmount != null || item.status === 2 || item.status === 4}}">
            <text wx:if="{{item.rewardAmount != null}}" class="reward-amount">奖励：¥{{item.rewardAmount}}</text>
            <text wx:elif="{{item.status === 2}}" class="reward-pending">奖励处理中</text>
          </view>
          <view wx:if="{{item.billStatus == 2 && !item.transferExpired}}" class="confirm-receive-wrap" catchtap="confirmReceive" data-item="{{item}}">
            <text class="confirm-receive-btn">确认收款</text>
          </view>
          <view wx:if="{{item.billStatus == 2 && item.transferExpired}}" class="confirm-receive-wrap">
            <text class="confirm-receive-btn confirm-receive-disabled">确认收款</text>
            <text class="expired-hint">奖励已过期，无法领取</text>
          </view>
          <text class="record-reason" wx:if="{{item.reason}}">原因: {{item.reason}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无上传记录</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 全屏视频播放器（隐藏，仅全屏时可见） -->
  <video wx:if="{{playingVideo}}" id="fullscreenVideo" src="{{playingVideo}}" autoplay="{{true}}" style="width:1px;height:1px;position:fixed;left:-100px;top:-100px;" bindfullscreenchange="onVideoFullscreenChange"></video>

  <!-- 昵称授权底部弹窗 -->
  <view class="profile-sheet-mask {{showProfileSheet ? 'profile-sheet-mask-show' : ''}}" bindtap="closeProfileSheet">
    <view class="profile-sheet {{showProfileSheet ? 'profile-sheet-show' : ''}}" catchtap="">
      <view class="profile-sheet-bar"></view>
      <text class="profile-sheet-title">设置昵称</text>
      <text class="profile-sheet-desc">点击输入框后，在键盘上方选择「微信昵称」即可一键填入</text>
      <view class="profile-nickname-row">
        <text class="nickname-icon">✏️</text>
        <input class="profile-nickname-input" type="nickname" placeholder="点击此处，选择微信昵称" value="{{wxNickname}}" bindinput="onNicknameChange" focus="{{showProfileSheet}}" />
      </view>
      <view class="profile-confirm-btn {{wxNickname ? '' : 'btn-disabled'}}" bindtap="confirmProfile">确认</view>
      <view class="sheet-skip-btn" bindtap="closeProfileSheet">暂不设置</view>
    </view>
  </view>
</view>
