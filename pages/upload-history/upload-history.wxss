.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  padding: 20rpx 30rpx;
}

/* 记录列表 */
.record-item {
  display: flex;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.record-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-video {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #333;
}

.play-icon {
  color: #fff;
  font-size: 48rpx;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 24rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.record-type {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.status-pass {
  background: #f6ffed;
  color: #52c41a;
}

.status-fail {
  background: #fff2f0;
  color: #ff4d4f;
}

.status-pending {
  background: #fffbe6;
  color: #faad14;
}

.status-claimed {
  background: #e6f7ff;
  color: #1890ff;
}

.reward-info {
  margin-top: 8rpx;
}

.reward-amount {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.reward-pending {
  font-size: 24rpx;
  color: #faad14;
}

.record-reason {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.confirm-receive-wrap {
  margin-top: 12rpx;
}

.confirm-receive-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #fff;
  background: #07c160;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}

.confirm-receive-disabled {
  background: #ccc;
  color: #fff;
}

.expired-hint {
  display: block;
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}
