<view class="page">
  <loading-overlay visible="{{showLoginLoading}}" text="{{loginLoadingText}}" />

  <!-- 顶部黄色区域（含用户信息） -->
  <view class="top-section">
    <!-- 游客 -->
    <view wx:if="{{!isLogin}}" class="user-section">
      <view class="avatar avatar-circle avatar-placeholder">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-detail">
        <text class="nickname">游客</text>
        <text class="guest-hint">登录后查看更多功能</text>
      </view>
    </view>
    <button wx:if="{{!isLogin}}" class="login-btn" bindtap="handleLogin">立即登录</button>

    <!-- 已登录 -->
    <view wx:if="{{isLogin}}" class="user-section">
      <image wx:if="{{userInfo.headImg}}" class="avatar avatar-circle" src="{{userInfo.headImg}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-circle avatar-placeholder">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-detail">
        <text class="nickname">{{userInfo.name || '微信用户'}}</text>
        <view class="user-id-row">
          <text class="user-id-text">ID：{{userInfo.userId || ''}}</text>
          <view class="copy-tag" bindtap="copyId">复制</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 白色内容卡片 -->
  <view class="content-card">

    <!-- 奖励统计（仅登录后） -->
    <view wx:if="{{isLogin}}" class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{statistics.totalReward}}</text>
        <text class="stat-label">合计奖励</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{statistics.caseReward || 0}}</text>
        <text class="stat-label">报案奖励</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{statistics.taskReward || 0}}</text>
        <text class="stat-label">任务奖励</text>
      </view>
    </view>

    <!-- 跑车必备神器 Banner -->
    <view class="ad-banner-wrap">
      <view class="ad-banner-swirl">
        <image class="ad-banner-swirl-img" src="/images/mine/top_decor.png" mode="widthFix" />
      </view>
      <view class="ad-banner-overlay">
        <text class="ad-banner-title">跑车必备神器</text>
        <view class="ad-banner-tag">
          <text class="ad-banner-tag-text">拍照5元—30元</text>
        </view>
        <image class="ad-banner-girl" src="/images/mine/camera_girl.png" mode="aspectFit" />
      </view>
    </view>

    <!-- 功能网格 -->
    <view class="func-grid">
      <view class="func-item" bindtap="goUploadHistory">
        <image class="func-icon-img" src="/images/mine/icon_upload_record.png" mode="aspectFit" />
        <text class="func-name">上传记录</text>
      </view>
      <view class="func-item" bindtap="onComingSoon">
        <image class="func-icon-img" src="/images/mine/icon_tutorial.png" mode="aspectFit" />
        <text class="func-name">使用教程</text>
      </view>
      <view class="func-item" bindtap="onComingSoon">
        <image class="func-icon-img" src="/images/mine/icon_notice.png" mode="aspectFit" />
        <text class="func-name">公告</text>
      </view>
      <view class="func-item">
        <button class="contact-btn" open-type="contact">
          <image class="func-icon-img" src="/images/mine/icon_service.png" mode="aspectFit" />
          <text class="func-name">在线客服</text>
        </button>
      </view>
      <view class="func-item" bindtap="onComingSoon">
        <image class="func-icon-img" src="/images/mine/icon_invite.png" mode="aspectFit" />
        <text class="func-name">邀请好友</text>
      </view>
      <view class="func-item" bindtap="onComingSoon">
        <image class="func-icon-img" src="/images/mine/icon_points.png" mode="aspectFit" />
        <text class="func-name">我的积分</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-btns">
      <button class="bottom-btn share-btn" open-type="share">
        <image class="bottom-btn-img" src="/images/mine/rect_share.png" mode="aspectFit" />
        <text class="bottom-btn-text">分享好友</text>
      </button>
      <view class="bottom-btn welfare-btn" bindtap="onWelfare">
        <image class="bottom-btn-img" src="/images/mine/rect_welfare.png" mode="aspectFit" />
        <text class="bottom-btn-text">加福利官</text>
      </view>
    </view>

  </view>

  <!-- 福利官弹窗 -->
  <view class="modal-mask" wx:if="{{showWelfareModal}}" bindtap="closeWelfareModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">添加福利官微信</text>
      <image class="qrcode-img" src="/images/kefu.jpg" mode="widthFix" show-menu-by-longpress="{{true}}" />
      <text class="modal-hint">长按二维码识别添加福利官</text>
      <view class="modal-close" bindtap="closeWelfareModal">关闭</view>
    </view>
  </view>

  <!-- 头像昵称弹窗 -->
  <view class="sheet-mask {{showProfileModal ? 'sheet-mask-show' : ''}}" bindtap="skipProfile">
    <view class="sheet-container {{showProfileModal ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-header">
        <text class="sheet-title">设置头像和昵称</text>
        <view class="sheet-close" bindtap="skipProfile">跳过</view>
      </view>
      <view class="sheet-body">
        <view class="sheet-row">
          <text class="sheet-label">头像</text>
          <button class="sheet-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{tempAvatarUrl}}" class="sheet-avatar-img" src="{{tempAvatarUrl}}" mode="aspectFill" />
            <view wx:else class="sheet-avatar-img sheet-avatar-empty">
              <text class="sheet-avatar-placeholder">+</text>
            </view>
            <text class="sheet-arrow">></text>
          </button>
        </view>
        <view class="sheet-row">
          <text class="sheet-label">昵称</text>
          <input class="sheet-nickname-input" type="nickname" placeholder="点击获取微信昵称" bindchange="onTempNicknameChange" value="{{tempNickname}}" />
        </view>
      </view>
      <view class="sheet-confirm-btn" bindtap="confirmProfile">确认</view>
    </view>
  </view>
</view>
