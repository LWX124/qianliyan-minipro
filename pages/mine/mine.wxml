<view class="page">
  <!-- 自定义登录 loading -->
  <loading-overlay visible="{{showLoginLoading}}" text="{{loginLoadingText}}" />
  <!-- 游客状态 -->
  <view wx:if="{{!isLogin}}" class="user-header guest-mode">
    <view class="user-info">
      <view class="avatar avatar-placeholder">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-detail">
        <text class="nickname">游客</text>
        <text class="guest-hint">登录后查看更多功能</text>
      </view>
    </view>
    <button class="login-btn" bindtap="handleLogin">立即登录</button>
  </view>

  <!-- 登录状态 -->
  <view wx:else class="user-header">
    <view class="user-info">
      <image wx:if="{{userInfo.headImg}}" class="avatar" src="{{userInfo.headImg}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-placeholder">
        <text class="avatar-text">👤</text>
      </view>
      <view class="user-detail">
        <text class="nickname">{{userInfo.name || '微信用户'}}</text>
      </view>
      <view class="logout-btn" bindtap="handleLogout">退出登录</view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{statistics.totalReward}}</text>
        <text class="stat-label">合计奖励</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{statistics.caseReward}}</text>
        <text class="stat-label">报案奖励</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{statistics.taskReward}}</text>
        <text class="stat-label">任务奖励</text>
      </view>
    </view>
  </view>

  <!-- 广告 banner 占位 -->
  <view class="ad-banner">
    <view class="ad-placeholder">
      <text class="ad-text">拍照 5元-20元</text>
    </view>
  </view>

  <!-- 功能网格 -->
  <view class="func-grid card">
    <view class="func-item" bindtap="goUploadHistory">
      <text class="func-icon">📋</text>
      <text class="func-name">上传记录</text>
    </view>
    <view class="func-item" bindtap="goRewardRecords">
      <text class="func-icon">🏆</text>
      <text class="func-name">奖励记录</text>
    </view>
    <view class="func-item" bindtap="onComingSoon">
      <text class="func-icon">📖</text>
      <text class="func-name">使用教程</text>
    </view>
    <view class="func-item" bindtap="onComingSoon">
      <text class="func-icon">📢</text>
      <text class="func-name">公告</text>
    </view>
    <view class="func-item">
      <button class="contact-btn" open-type="contact">
        <text class="func-icon">💬</text>
        <text class="func-name">在线客服</text>
      </button>
    </view>
    <view class="func-item" bindtap="onComingSoon">
      <text class="func-icon">👥</text>
      <text class="func-name">邀请好友</text>
    </view>
    <view class="func-item" bindtap="onComingSoon">
      <text class="func-icon">🏅</text>
      <text class="func-name">我的积分</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-btns">
    <button class="bottom-btn share-btn" open-type="share">
      <text>分享好友</text>
      <text class="btn-icon">↗</text>
    </button>
    <view class="bottom-btn welfare-btn" bindtap="onWelfare">
      <text>加福利官</text>
      <text class="btn-icon">🎁</text>
    </view>
  </view>

  <!-- 福利官弹窗 -->
  <view class="modal-mask" wx:if="{{showWelfareModal}}" bindtap="closeWelfareModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">添加福利官微信</text>
      <view class="qrcode-placeholder">
        <text class="qrcode-text">微信二维码</text>
        <text class="qrcode-sub">（即将上线）</text>
      </view>
      <text class="modal-hint">长按识别二维码添加福利官</text>
      <view class="modal-close" bindtap="closeWelfareModal">关闭</view>
    </view>
  </view>

  <!-- 微信头像昵称底部弹窗 -->
  <view class="sheet-mask {{showProfileModal ? 'sheet-mask-show' : ''}}" bindtap="skipProfile">
    <view class="sheet-container {{showProfileModal ? 'sheet-show' : ''}}" catchtap="">
      <view class="sheet-header">
        <text class="sheet-title">设置头像和昵称</text>
        <view class="sheet-close" bindtap="skipProfile">跳过</view>
      </view>
      <view class="sheet-body">
        <view class="sheet-row">
          <text class="sheet-label">头像</text>
          <button class="sheet-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{tempAvatarUrl}}" class="sheet-avatar-img" src="{{tempAvatarUrl}}" mode="aspectFill" />
            <view wx:else class="sheet-avatar-img sheet-avatar-empty">
              <text class="sheet-avatar-placeholder">+</text>
            </view>
            <text class="sheet-arrow">></text>
          </button>
        </view>
        <view class="sheet-row">
          <text class="sheet-label">昵称</text>
          <input class="sheet-nickname-input" type="nickname" placeholder="点击获取微信昵称" bindchange="onTempNicknameChange" value="{{tempNickname}}" />
        </view>
      </view>
      <view class="sheet-confirm-btn" bindtap="confirmProfile">确认</view>
    </view>
  </view>
</view>
