.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8d5f5 0%, #f5f5f5 25%);
}

/* 用户信息头部 */
.user-header {
  padding: 40rpx 30rpx 30rpx;
  position: relative;
}

/* 游客模式 */
.guest-mode {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.guest-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.guest-mode .nickname {
  color: #fff;
}

.login-btn {
  margin-top: 32rpx;
  background: #fff;
  color: #667eea;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  line-height: 1;
}

.login-btn::after {
  border: none;
}

/* 登出按钮 */
.logout-btn {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 60rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
  gap: 12rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 统计数据 */
.stats-row {
  display: flex;
  text-align: center;
}

.stat-item {
  flex: 1;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 广告 banner */
.ad-banner {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.ad-placeholder {
  height: 160rpx;
  background: linear-gradient(135deg, #ffd89b, #ff9a76);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

/* 功能网格 */
.func-grid {
  margin: 0 30rpx 20rpx;
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 0;
}

.func-item {
  width: 25%;
  text-align: center;
  padding: 24rpx 0;
  overflow: hidden;
}

.func-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.func-name {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 客服按钮样式重置 */
.contact-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
  font-size: inherit;
  display: flex !important;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  box-sizing: border-box;
  min-height: 0 !important;
  height: auto !important;
  border-radius: 0 !important;
  overflow: hidden;
}

.contact-btn::after {
  border: none;
}

/* 底部按钮 */
.bottom-btns {
  display: flex;
  padding: 20rpx 30rpx 40rpx;
  gap: 20rpx;
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #333;
  gap: 12rpx;
  border: none;
  line-height: 1;
}

.bottom-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

/* 福利官弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.qrcode-placeholder {
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.qrcode-text {
  font-size: 30rpx;
  color: #999;
}

.qrcode-sub {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.modal-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.modal-close {
  display: inline-block;
  padding: 16rpx 80rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
