.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  padding: 30rpx;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.photo-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.add-btn {
  background: #fff;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 底部操作 */
.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.photo-count {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn-take, .btn-upload {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-take {
  background: #ff4d4f;
  color: #fff;
}

.btn-upload {
  background: #ff4d4f;
  color: #fff;
}

/* 上传遮罩 */
.uploading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.uploading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 80rpx;
}

/* 环形进度条 */
.progress-ring {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  margin-bottom: 36rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid rgba(255, 255, 255, 0.15);
  box-sizing: border-box;
}

.ring-left-wrap,
.ring-right-wrap {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.ring-left-wrap {
  left: 0;
}

.ring-right-wrap {
  right: 0;
}

.ring-half {
  position: absolute;
  top: 0;
  width: 200%;
  height: 100%;
  border-radius: 50%;
  border: 12rpx solid #ff4d4f;
  box-sizing: border-box;
  border-right-color: transparent;
  border-bottom-color: transparent;
  transition: transform 0.3s ease;
}

.ring-left {
  left: 0;
  transform-origin: right center;
  transform: rotate(-180deg);
}

.ring-right {
  right: 0;
  transform-origin: left center;
  transform: rotate(-180deg);
}

.ring-inner {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-percent {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.uploading-text {
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 12rpx;
}

.uploading-hint {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

/* ---- 手机号授权底部弹窗 ---- */
.phone-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.phone-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 40rpx 0;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.phone-sheet-bar {
  width: 80rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.phone-sheet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.phone-sheet-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.phone-sheet-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 0;
}

.phone-sheet-btn::after {
  border: none;
}

.sheet-skip-btn {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0 16rpx;
}
