<view class="page">
  <view class="container">
    <!-- 已拍照片列表 -->
    <view class="photo-grid" wx:if="{{photos.length > 0}}">
      <view class="photo-item" wx:for="{{photos}}" wx:key="index">
        <image class="photo-img" src="{{item}}" mode="aspectFill" bindtap="previewPhoto" data-index="{{index}}"></image>
        <view class="photo-delete" bindtap="deletePhoto" data-index="{{index}}">×</view>
      </view>
      <!-- 添加更多按钮 -->
      <view class="photo-item add-btn" bindtap="takeMore" wx:if="{{photos.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">继续拍照</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{photos.length === 0}}">
      <view class="empty-icon">📷</view>
      <text class="empty-text">点击下方按钮开始拍照</text>
      <text class="empty-hint">最多可拍9张照片</text>
    </view>

    <!-- 底部操作区 -->
    <view class="bottom-area">
      <view class="photo-count" wx:if="{{photos.length > 0}}">
        已拍 {{photos.length}}/9 张
      </view>
      <view class="btn-row">
        <view class="btn-take" bindtap="takePhoto" wx:if="{{photos.length === 0}}">
          开始拍照
        </view>
        <view class="btn-upload" bindtap="uploadPhotos" wx:if="{{photos.length > 0}}">
          上传 ({{photos.length}}张)
        </view>
      </view>
    </view>
  </view>

  <!-- 上传遮罩 -->
  <view class="uploading-mask" wx:if="{{uploading}}">
    <view class="uploading-content">
      <text class="uploading-text">上传中 {{uploadedCount}}/{{photos.length}}</text>
    </view>
  </view>
</view>
