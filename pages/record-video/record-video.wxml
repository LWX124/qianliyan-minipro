<view class="page">
  <!-- Layer 1: Camera 预览 (idle/recording/paused) -->
  <camera
    wx:if="{{status !== 'preview' && status !== 'uploading' && !cameraError}}"
    class="camera-preview"
    device-position="{{devicePosition}}"
    flash="{{flashMode}}"
    resolution="medium"
    bindinitdone="onCameraReady"
    binderror="onCameraError"
  />

  <!-- Layer 1: Video 预览 (preview) -->
  <view class="preview-container" wx:if="{{status === 'preview'}}">
    <video
      class="preview-video"
      src="{{videoPath}}"
      controls="{{false}}"
      show-center-play-btn="{{true}}"
      show-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      enable-progress-gesture="{{false}}"
    />
    <text class="preview-duration">{{durationDisplay}}</text>
  </view>

  <!-- 降级模式占位 -->
  <view class="fallback-placeholder" wx:if="{{status !== 'preview' && cameraError}}">
    <text class="fallback-text">点击下方按钮录制视频</text>
    <text class="fallback-sub">将调用系统相机</text>
  </view>

  <!-- Layer 2: 自定义导航栏 (录制中也显示) -->
  <view class="custom-nav" wx:if="{{status !== 'uploading'}}"
        style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <view class="nav-back-arrow"></view>
      </view>
      <text class="nav-title">录制视频</text>
    </view>
  </view>

  <!-- Layer 3: 右侧缩放控制按钮 -->
  <view class="zoom-controls"
        wx:if="{{supportZoom && (status === 'idle' || status === 'recording') && !cameraError}}">
    <view class="zoom-btn" bindtap="zoomReset">
      <text class="zoom-btn-text">恢复</text>
      <text class="zoom-btn-text">1倍</text>
    </view>
    <view class="zoom-btn" bindtap="zoomIn">
      <text class="zoom-btn-icon">+</text>
    </view>
    <view class="zoom-btn zoom-display-btn">
      <text class="zoom-display-text">{{zoomDisplay}}X</text>
    </view>
    <view class="zoom-btn" bindtap="zoomOut">
      <text class="zoom-btn-icon">−</text>
    </view>
  </view>

  <!-- Layer 3: 引导提示（左下角常驻） -->
  <view class="guide-tips"
        wx:if="{{(status === 'recording' || status === 'idle') && !cameraError}}">
    <view class="guide-tip-row">
      <view class="guide-check-icon">✓</view>
      <text class="guide-tip-text">角度找好，左右拍全，拉近距离，减少晃动</text>
    </view>
    <view class="guide-tip-row">
      <view class="guide-check-icon">✓</view>
      <text class="guide-tip-text">记得拍清品牌和车牌</text>
    </view>
  </view>

  <!-- Layer 4: 底部控制区 -->
  <view class="bottom-controls">

    <!-- 计时器 -->
    <view class="timer-row" wx:if="{{status === 'recording' || status === 'paused'}}">
      <view class="recording-dot {{status === 'paused' ? 'dot-blink' : 'dot-pulse'}}"></view>
      <text class="timer-text {{status === 'paused' ? 'timer-blink' : ''}}">{{timerDisplay}}</text>
    </view>

    <!-- recording 控制: 5秒后显示暂停按钮 -->
    <view class="control-row" wx:if="{{status === 'recording' && showPauseBtn}}">
      <view class="ctrl-placeholder"></view>
      <view class="pause-circle-btn" bindtap="stopRecord">
        <view class="pause-icon-bar"></view>
        <view class="pause-icon-bar"></view>
      </view>
      <view class="switch-btn" bindtap="switchCamera">
        <view class="switch-camera-icon"></view>
      </view>
    </view>

    <!-- preview 控制: 重拍 + 确定 -->
    <view class="control-row preview-row" wx:if="{{status === 'preview'}}">
      <view class="rerecord-btn" bindtap="reRecord">
        <view class="rerecord-icon-wrap">
          <view class="rerecord-arrow"></view>
        </view>
        <text class="rerecord-text">重拍</text>
      </view>
      <view class="confirm-btn" bindtap="uploadVideo">
        <view class="confirm-check"></view>
        <text class="confirm-text">确定</text>
      </view>
    </view>
  </view>

  <!-- 上传遮罩 -->
  <view class="uploading-mask" wx:if="{{uploading}}">
    <view class="uploading-content">
      <view class="uploading-spinner">
        <view class="spinner-dot" wx:for="{{3}}" wx:key="*this"></view>
      </view>
      <text class="uploading-label" wx:if="{{compressing}}">压缩中...</text>
      <text class="uploading-label" wx:elif="{{uploadProgress > 0 && uploadProgress < 100}}">上传中 {{uploadProgress}}%</text>
      <text class="uploading-label" wx:else>上传中...</text>
    </view>
  </view>

  <!-- 手机号授权底部弹窗 -->
  <view class="phone-sheet-mask" wx:if="{{showPhoneModal}}" bindtap="closePhoneModal">
    <view class="phone-sheet" catchtap="">
      <view class="phone-sheet-bar"></view>
      <text class="phone-sheet-title">绑定手机号</text>
      <text class="phone-sheet-desc">绑定手机号后可正常领取奖励，我们承诺不会泄露您的信息</text>
      <button
        class="phone-sheet-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >一键授权手机号</button>
      <view class="sheet-skip-btn" bindtap="closePhoneModal">暂不绑定</view>
    </view>
  </view>
</view>