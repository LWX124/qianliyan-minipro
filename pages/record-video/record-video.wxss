.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

/* 引导区 */
.guide-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.guide-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.guide-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.guide-desc {
  color: #aaa;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.guide-tip {
  color: #666;
  font-size: 22rpx;
}

/* 预览视频 */
.preview-video {
  flex: 1;
  width: 100%;
}

.video-info {
  padding: 16rpx 30rpx;
  background: #000;
}

.duration-text {
  color: #aaa;
  font-size: 26rpx;
}

/* 控制区 */
.controls {
  padding: 40rpx 30rpx 80rpx;
  text-align: center;
  background: #000;
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.record-btn-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.control-hint {
  display: block;
  color: #aaa;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.btn-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.cancel-btn, .upload-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.upload-btn {
  background: #ff4d4f;
  color: #fff;
}

/* 上传遮罩 */
.uploading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.uploading-content {
  background: rgba(0, 0, 0, 0.8);
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
}

.uploading-text {
  color: #fff;
  font-size: 30rpx;
}
