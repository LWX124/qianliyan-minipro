.page {
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
}

/* ========== Camera / Video 全屏 ========== */
.camera-preview {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.preview-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ========== 降级占位 ========== */
.fallback-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.fallback-text {
  color: #fff;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.fallback-sub {
  color: #888;
  font-size: 24rpx;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), transparent);
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  margin-left: 8rpx;
}

/* ========== 引导提示 ========== */
.guide-overlay {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.55);
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  z-index: 5;
  opacity: 1;
  transition: opacity 1s ease-out;
}

.guide-fade-out {
  opacity: 0;
  pointer-events: none;
}

.guide-tip-item {
  color: #fff;
  font-size: 34rpx;
  line-height: 2;
  white-space: nowrap;
}

.guide-duration {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: center;
}

/* ========== 底部控制区 ========== */
.bottom-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 10;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
}

/* ========== 缩放滑条 ========== */
.zoom-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 0 20rpx;
}

.zoom-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  width: 50rpx;
  text-align: center;
}

.zoom-slider {
  flex: 1;
  margin: 0 10rpx;
}

.zoom-display {
  display: block;
  text-align: center;
  color: #FFD700;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

/* ========== 计时器 ========== */
.timer-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.recording-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.dot-pulse {
  animation: pulse 1.5s ease-in-out infinite;
}

.dot-blink {
  animation: blink 1s step-end infinite;
}

.timer-text {
  color: #fff;
  font-size: 36rpx;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.timer-blink {
  animation: blink 1s step-end infinite;
}

.status-label {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

/* ========== 控制按钮行 ========== */
.control-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 40rpx;
}

.ctrl-placeholder {
  width: 80rpx;
}

/* 录制按钮 (idle) */
.record-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-btn-inner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

/* 停止按钮 (recording) */
.stop-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stop-btn-inner {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: #ff4d4f;
}

/* 暂停按钮 */
.pause-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.pause-icon-bar {
  width: 6rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* 继续按钮 */
.resume-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.resume-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 20rpx 0 20rpx 36rpx;
  border-color: transparent transparent transparent #fff;
  margin-left: 8rpx;
}

/* 小停止按钮 (paused) */
.stop-btn-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.stop-square {
  width: 28rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #ff4d4f;
}

/* 切换摄像头 */
.switch-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.switch-text {
  color: #fff;
  font-size: 22rpx;
}

/* preview 按钮 */
.action-btn {
  width: 240rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.upload-btn {
  background: #ff4d4f;
  color: #fff;
}

/* ========== 上传遮罩 ========== */
.uploading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.uploading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.uploading-spinner {
  display: flex;
  gap: 16rpx;
}

.spinner-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #fff;
  animation: bounce 1.2s ease-in-out infinite;
}

.spinner-dot:nth-child(2) {
  animation-delay: 0.16s;
}

.spinner-dot:nth-child(3) {
  animation-delay: 0.32s;
}

.uploading-label {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* ========== 动画 ========== */
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

@keyframes blink {
  0%, 49% { opacity: 1; }
  50%, 100% { opacity: 0; }
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.4);
    opacity: 0.3;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}
