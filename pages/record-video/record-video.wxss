.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

.camera {
  flex: 1;
  width: 100%;
  position: relative;
}

.preview-video {
  flex: 1;
  width: 100%;
}

/* 计时器 */
.timer-overlay {
  position: absolute;
  top: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.5);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.timer-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff4d4f;
  margin-right: 12rpx;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.timer-text {
  color: #fff;
  font-size: 28rpx;
  font-variant-numeric: tabular-nums;
}

/* 控制区 */
.controls {
  padding: 40rpx 30rpx 80rpx;
  text-align: center;
  background: #000;
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.record-btn-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.control-hint {
  display: block;
  color: #aaa;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.btn-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.cancel-btn, .stop-btn, .upload-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.stop-btn {
  background: #ff4d4f;
  color: #fff;
}

.stop-btn.disabled {
  background: rgba(255, 77, 79, 0.3);
  color: rgba(255, 255, 255, 0.5);
}

.upload-btn {
  background: #ff4d4f;
  color: #fff;
}

/* 上传遮罩 */
.uploading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.uploading-content {
  background: rgba(0, 0, 0, 0.8);
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
}

.uploading-text {
  color: #fff;
  font-size: 30rpx;
}

.tip-text {
  display: block;
  color: #666;
  font-size: 22rpx;
  margin-top: 12rpx;
}
