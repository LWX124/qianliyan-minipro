<view class="page">
  <!-- 自定义登录 loading -->
  <loading-overlay visible="{{showLoginLoading}}" text="{{loginLoadingText}}" />

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="custom-nav-content">
      <text class="custom-nav-title">事故随手拍</text>
    </view>
  </view>

  <!-- 顶部 Banner（黄色背景 + 文字 + 女生插画），图片已包含文字 -->
  <view class="banner-section" style="padding-top: {{navBarHeight}}px;">
    <image class="banner-bg" src="/images/apply/group_accident.png" mode="aspectFill" />
  </view>

  <!-- 白色主卡片（圆角上叠 Banner） -->
  <view class="main-card">

    <!-- 必备神器说明栏 -->
    <view class="section-header">
      <view class="section-header-left">
        <text class="section-header-title">必备神器</text>
        <text class="section-header-desc">推荐使用录制事故视频</text>
      </view>
      <image class="section-header-car" src="/images/apply/car_crash.png" mode="aspectFit" />
    </view>

    <!-- 录制视频卡片（推荐） -->
    <view class="action-card video-card" bindtap="goRecordVideo">
      <image class="action-card-bg" src="/images/apply/group_card_video.png" mode="aspectFill" />
      <view class="action-card-content">
        <view class="action-card-left">
          <image class="recommend-badge" src="/images/apply/badge_recommend.png" mode="aspectFit" />
          <text class="action-card-title">开始录制事故视频</text>
          <text class="action-card-desc">每次都有5元—30元现金奖励</text>
        </view>
      </view>
    </view>

    <!-- 拍照上传卡片 -->
    <view class="action-card photo-card" bindtap="goTakePhoto">
      <image class="action-card-bg" src="/images/apply/group_card_photo.png" mode="aspectFill" />
      <view class="action-card-content">
        <view class="action-card-left">
          <text class="action-card-title">拍照上传事故图片</text>
          <text class="action-card-desc">随手拍张照片上传事故现场</text>
        </view>
      </view>
    </view>

    <!-- 领取奖励按钮 -->
    <view class="bind-btn" bindtap="goUploadHistory">
      <text class="bind-btn-text">领取奖励</text>
    </view>

  </view>

  <!-- 手机号授权底部弹窗 -->
  <view class="phone-sheet-mask" wx:if="{{showPhoneModal}}" bindtap="skipPhoneBind">
    <view class="phone-sheet" catchtap="">
      <view class="phone-sheet-bar"></view>
      <text class="phone-sheet-title">授权手机号</text>
      <text class="phone-sheet-desc">为保障您的权益，上传事故视频需要绑定手机号，我们承诺不会泄露您的信息</text>
      <button
        class="phone-sheet-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >一键授权手机号</button>
      <view class="phone-sheet-skip" bindtap="skipPhoneBind">暂不授权</view>
    </view>
  </view>

  <!-- 福利官弹窗 -->
  <view class="modal-mask" wx:if="{{showWelfareModal}}" bindtap="closeWelfareModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">添加福利官微信</text>
      <image class="qrcode-img" src="/images/kefu.jpg" mode="widthFix" show-menu-by-longpress="{{true}}" />
      <text class="modal-hint">长按二维码识别添加福利官</text>
      <view class="modal-close" bindtap="closeWelfareModal">关闭</view>
    </view>
  </view>
</view>
