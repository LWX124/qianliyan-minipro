<view class="page">
  <!-- 自定义登录 loading -->
  <loading-overlay visible="{{showLoginLoading}}" text="{{loginLoadingText}}" />
  <!-- 顶部 banner -->
  <view class="banner">
    <image class="banner-img" src="/images/banner.jpg" mode="aspectFill" />
  </view>

  <!-- 主内容卡片 -->
  <view class="main-card">
    <!-- 事故车辆插画 -->
    <view class="accident-illustration">
      <image class="illustration-img" src="/images/accident.jpg" mode="aspectFit" />
    </view>

    <!-- 推荐标签 + 录制视频卡片 -->
    <view class="action-card video-card" bindtap="goRecordVideo">
      <view class="recommend-tag">
        <text class="tag-text">推荐</text>
      </view>
      <view class="action-icon">
        <view class="icon-circle video-icon-bg">
          <text>🎬</text>
        </view>
      </view>
      <text class="action-text">开始录制事故视频</text>
    </view>

    <!-- 拍照上传卡片 -->
    <view class="action-card photo-card" bindtap="goTakePhoto">
      <view class="action-icon">
        <view class="icon-circle photo-icon-bg">
          <text>🖼</text>
        </view>
      </view>
      <text class="action-text">拍照上传事故照片</text>
    </view>

    <!-- 温馨提示 -->
    <view class="tips">
      <text class="tips-line tip-warning">温馨提示：不推荐拍照，通过率低</text>
    </view>
  </view>

  <!-- 底部按钮区 -->
  <view class="bottom-btns">
    <button class="bottom-btn share-btn" open-type="share">
      <text>分享好友</text>
      <text class="btn-icon">↗</text>
    </button>
    <view class="bottom-btn welfare-btn" bindtap="onWelfare">
      <text>加福利官</text>
      <text class="btn-icon">🎁</text>
    </view>
  </view>

  <!-- 福利官弹窗 -->
  <view class="modal-mask" wx:if="{{showWelfareModal}}" bindtap="closeWelfareModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">添加福利官微信</text>
      <view class="qrcode-placeholder">
        <text class="qrcode-text">微信二维码</text>
        <text class="qrcode-sub">（即将上线）</text>
      </view>
      <text class="modal-hint">长按识别二维码添加福利官</text>
      <view class="modal-close" bindtap="closeWelfareModal">关闭</view>
    </view>
  </view>
</view>
