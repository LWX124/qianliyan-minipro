/* ===== 申请页面 ===== */
.page {
  background: #eceef2;
  min-height: 100vh;
}

/* ---- 自定义导航栏 ---- */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background: #f9f4a2;
}

.custom-nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #010005;
}

/* ---- Banner 区域 ---- */
.banner-section {
  position: relative;
  width: 750rpx;
  height: 520rpx;
  background: linear-gradient(180deg, #f9f4a2 0%, #f9f4a2 100%);
  overflow: hidden;
}

.banner-bg {
  width: 750rpx;
  height: 520rpx;
  display: block;
  margin-top: -40rpx;
}

/* ---- 白色主卡片（上叠 Banner） ---- */
.main-card {
  position: relative;
  margin-top: -150rpx;
  background: #fff;
  border-radius: 48rpx 48rpx 24rpx 24rpx;
  border: 2rpx solid #fff;
  padding: 0 40rpx 60rpx;
  min-height: 60vh;
}

/* ---- 必备神器说明栏 ---- */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 170rpx;
  padding: 0 20rpx 0 40rpx;
  background: linear-gradient(180deg, #fffdd8 0%, #fff 100%);
  border-radius: 48rpx 48rpx 0 0;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  margin: 0 -40rpx;
  box-sizing: border-box;
}

.section-header-left {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #010005;
  line-height: 1.4;
}

.section-header-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1;
}

.section-header-car {
  width: 360rpx;
  height: 200rpx;
  flex-shrink: 0;
  margin-right: -10rpx;
}

/* ---- 功能卡片通用 ---- */
.action-card {
  position: relative;
  width: 100%;
  height: 220rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.action-card:first-of-type {
  margin-top: 24rpx;
}

.action-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.action-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  height: 100%;
  padding: 0 0 0 62rpx;
  box-sizing: border-box;
}

.action-card-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  max-width: 65%;
}

/* "推荐" 角标 */
.recommend-badge {
  position: absolute;
  left: 32rpx;
  top: 2rpx;
  width: 160rpx;
  height: 52rpx;
  z-index: 2;
}

.action-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #010005;
  line-height: 1.2;
}

.action-card-desc {
  font-size: 26rpx;
  color: rgba(119, 111, 56, 1);
  margin-top: 16rpx;
  line-height: 1.7;
}

/* ---- 视频卡片 + 流光动效 ---- */
.video-card {
  /* 视频卡片背景已包含渐变 + 图标 */
}

.video-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    120deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.15) 40%,
    rgba(255, 255, 255, 0.4) 50%,
    rgba(255, 255, 255, 0.15) 60%,
    rgba(255, 255, 255, 0) 100%
  );
  z-index: 3;
  animation: shimmer 5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  60% {
    left: 150%;
  }
  100% {
    left: 150%;
  }
}

/* ---- 拍照卡片 ---- */
.photo-card {
  /* 背景形状由 group_card_photo.png 控制，与视频卡片保持一致 */
}

/* ---- 领取奖励按钮 ---- */
.bind-btn {
  margin-top: 36rpx;
  background: linear-gradient(136deg, #ffc940 0%, #ffecab 100%);
  border-radius: 24rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-btn-text {
  font-size: 32rpx;
  font-weight: 400;
  color: #010005;
}

/* ---- 福利官弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.qrcode-img {
  width: 400rpx;
  display: block;
  margin: 0 auto 24rpx;
  border-radius: 16rpx;
}

.modal-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.modal-close {
  display: inline-block;
  padding: 16rpx 80rpx;
  background: linear-gradient(135deg, #fdd835, #f5a623);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.phone-auth-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  border: none;
  padding: 20rpx 0;
}

/* 底部弹起手机号授权 */
.phone-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: -200rpx; /* 延伸到 tabbar 下方确保背景遮住 */
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.phone-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 40rpx 0;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.phone-sheet-bar {
  width: 80rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.phone-sheet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.phone-sheet-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.phone-sheet-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.phone-sheet-btn::after {
  border: none;
}

.phone-auth-btn::after {
  border: none;
}

/* ---- 弹窗跳过按钮 ---- */
.sheet-skip-btn {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0 16rpx;
}
